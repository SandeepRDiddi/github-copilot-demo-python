MCP_POSTGRES_CONNECT_TIMEOUT_SECONDS=10
MCP_POSTGRES_STATEMENT_TIMEOUT_MS=15000
MCP_POSTGRES_DEFAULT_ROW_LIMIT=200
MCP_POSTGRES_MAX_ROW_LIMIT=1000
MCP_POSTGRES_VALIDATE_ON_STARTUP=true
MCP_GITHUB_ENABLED=false
MCP_GITHUB_TOKEN=
MCP_SLACK_ENABLED=false
