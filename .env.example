MCP_SERVER_NAME=Multi Integration MCP
MCP_ENVIRONMENT=development
MCP_TRANSPORT=stdio
MCP_LOG_LEVEL=INFO
MCP_WORKSPACE_ENABLED=true
MCP_WORKSPACE_ROOT=/Users/sandeepdiddi/Documents/New project
MCP_WORKSPACE_EXCLUDE_HIDDEN=true
MCP_WORKSPACE_MAX_ENTRIES=100
MCP_WORKSPACE_MAX_READ_CHARS=20000
MCP_POSTGRES_ENABLED=false
